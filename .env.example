# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
AUTH_URL=http://localhost:3000
AUTH_SECRET=replace-with-a-random-secret-from-openssl-rand-base64-32

# Database
DATABASE_URL=postgresql://utilitybox:utilitybox@localhost:5432/utilitybox?schema=public

# Registration / invite controls
ALLOW_PUBLIC_REGISTRATION=false
REQUIRE_INVITE_CODE=true
BOOTSTRAP_FIRST_USER_AS_ADMIN=false

# Seed admin account
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMe123!Strong
SEED_ADMIN_NAME=UtilityBox Admin

# Processing limits
MAX_UPLOAD_MB=50
MAX_BATCH_FILES=10
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=20
VIDEO_DOWNLOAD_MAX_MB=250

# Optional email provider for future password reset implementation
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
